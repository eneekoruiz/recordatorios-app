# Recordatorios Elite — Environment Variables
# Copy this file to `.env` and fill in your values to start in Production.

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Cadena de conexión a tu base de datos PostgreSQL (Neon, Supabase DB, Render, Railway).
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# ============================================
# S3 / CLOUDFLARE R2 STORAGE (Opcional)
# ============================================
# Si dejas esto vacío, los adjuntos se guardarán como Base64 en la base de datos o se deshabilitarán.
S3_REGION="auto"
S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID="tu-access-key"
S3_SECRET_ACCESS_KEY="tu-secret-key"
S3_BUCKET_NAME="recordatorios-bucket"
S3_PUBLIC_DOMAIN="https://tu-dominio-publico.com"

# ============================================
# APP CONFIG (Zero-Config)
# ============================================
# La PWA funciona en modo 100% Offline-First (Dexie.js).
# Si no proporcionas una DATABASE_URL, la app funcionará enteramente de forma local en tu navegador.
VITE_APP_NAME="Recordatorios Elite"
